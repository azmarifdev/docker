{
    "name": "server-api",
    "version": "1.0.0",
    "description": "Simple Express server with MongoDB for Docker learning",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",

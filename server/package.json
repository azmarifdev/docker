        "cors": "^2.8.5",
        "dotenv": "^16.3.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.16",
        "@types/node": "^20.0.0",
        "typescript": "^5.0.0",
        "ts-node-dev": "^2.0.0",
        "rimraf": "^5.0.0"
    }
}

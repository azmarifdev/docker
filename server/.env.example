# Database Configuration
# Replace with your actual MongoDB connection string
DB_URI=mongodb://localhost:27017/dockerapp

# Server Configuration
PORT=5000
NODE_ENV=development

# Security Keys (REPLACE WITH STRONG SECRETS IN PRODUCTION!)
# Generate strong secrets: https://generate-secret.vercel.app/32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
API_KEY=your_api_key_replace_this_with_actual_key

# Optional: CORS Configuration
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Optional: Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Optional: Session Configuration
# SESSION_SECRET=your_session_secret_key

# Optional: Email Configuration (if needed)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# Optional: Cloud Database (MongoDB Atlas example)
# DB_URI=mongodb+srv://username:password@cluster.mongodb.net/dockerapp?retryWrites=true&w=majority

# Optional: Redis Configuration (if using Redis for caching)
# REDIS_URL=redis://localhost:6379

# Optional: File Upload Configuration
# MAX_FILE_SIZE=5242880
# UPLOAD_DIR=uploads/

# Production Settings (uncomment for production)
# NODE_ENV=production
# DB_URI=your_production_mongodb_url
# JWT_SECRET=your_production_jwt_secret
# API_KEY=your_production_api_key

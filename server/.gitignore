# Environment variables (VERY IMPORTANT - Never commit these!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript build output
dist/
build/
*.tsbuildinfo

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Database files
*.sqlite
*.sqlite3
*.db
database.json

# MongoDB dump files
dump/

# Coverage directory used by tools like istanbul
coverage/
.nyc_output/

# ESLint cache
.eslintcache

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/

# JWT secrets and API keys (if stored in files)
secrets/
keys/
*.pem
*.key
*.crt

# Upload directories
uploads/
files/

# Session store files
sessions/
